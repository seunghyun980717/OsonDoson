+package com.reactnativemediapipe.handdetection
+
+import com.facebook.react.bridge.Arguments
+import com.facebook.react.bridge.WritableMap
+import com.facebook.react.bridge.WritableNativeArray
+import com.facebook.react.bridge.WritableNativeMap
+import com.google.mediapipe.tasks.vision.handlandmarker.HandLandmarkerResult
+import com.reactnativemediapipe.shared.landmarkToWritableMap
+import com.reactnativemediapipe.shared.normalizedLandmarkToWritableMap
+
+
+fun convertResultBundleToWritableMap(resultBundle: HandDetectorHelper.ResultBundle): WritableMap {
+  val map = Arguments.createMap()
+  val resultsArray = Arguments.createArray()
+  resultBundle.results.forEach { result ->
+    resultsArray.pushMap(handLandmarkerResultToWritableMap(result))
+  }
+  map.putArray("results", resultsArray)
+  map.putInt("inputImageHeight", resultBundle.inputImageHeight)
+  map.putInt("inputImageWidth", resultBundle.inputImageWidth)
+  map.putDouble("inferenceTime", resultBundle.inferenceTime.toDouble())
+  return map
+}
+
+fun handLandmarkerResultToWritableMap(result: HandLandmarkerResult): WritableMap {
+  val resultMap = WritableNativeMap()
+  val landmarksArray = WritableNativeArray()
+  val worldLandmarksArray = WritableNativeArray()
+  val handednessArray = WritableNativeArray()
+
+  result.landmarks().forEach { landmarks ->
+    val landmarkArray = WritableNativeArray()
+    landmarks.forEach { landmarkArray.pushMap(normalizedLandmarkToWritableMap(it)) }
+    landmarksArray.pushArray(landmarkArray)
+  }
+
+  result.worldLandmarks().forEach { worldLandmarks ->
+    val worldLandmarkArray = WritableNativeArray()
+    worldLandmarks.forEach { worldLandmarkArray.pushMap(landmarkToWritableMap(it)) }
+    worldLandmarksArray.pushArray(worldLandmarkArray)
+  }
+
+  // handedness — 손별로 "Left"/"Right" 분류 (수어 좌/우 손 구분에 핵심)
+  result.handednesses().forEach { handCategories ->
+    val categoryArray = WritableNativeArray()
+    handCategories.forEach { category ->
+      val categoryMap = WritableNativeMap()
+      categoryMap.putString("categoryName", category.categoryName())
+      categoryMap.putString("displayName", category.displayName())
+      categoryMap.putDouble("score", category.score().toDouble())
+      categoryMap.putInt("index", category.index())
+      categoryArray.pushMap(categoryMap)
+    }
+    handednessArray.pushArray(categoryArray)
+  }
+
+  resultMap.putArray("landmarks", landmarksArray)
+  resultMap.putArray("worldLandmarks", worldLandmarksArray)
+  resultMap.putArray("handedness", handednessArray)
+
+  return resultMap
+}
