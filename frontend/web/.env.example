# Spring API base URL.
# - 비워두면 axios/fetch가 상대경로(/api/...)로 호출 -> vite dev proxy(서버 host:port + /api)로 전달됨
# - 운영 빌드에서는 절대 URL 지정 권장 (예: https://api.example.com)
VITE_API_BASE_URL=https://k14e104.p.ssafy.io/api

# (dev 전용) /api 프록시 타깃. 비우면 http://localhost:8080 으로 폴백.
VITE_DEV_PROXY_TARGET=http://localhost:8080
